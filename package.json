{
  "name": "game-topup-shop",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "prisma:generate": "npm run prisma:generate --workspace=backend",
    "prisma:migrate": "npm run prisma:migrate --workspace=backend",
    "prisma:seed": "npm run prisma:seed --workspace=backend",
    "render:build": "NPM_CONFIG_PRODUCTION=false npm install && npx prisma generate --schema=backend/prisma/schema.prisma && npm run build:frontend && npm run build:backend",
    "render:start": "node backend/dist/server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
